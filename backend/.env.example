# TerraLedger Backend Configuration
# Copy this to .env and fill in your values

# Application
APP_NAME=TerraLedger
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://terraledger:terraledger@localhost:5432/terraledger_db

# Satellite Mode: "demo" uses cached data, "live" uses Google Earth Engine
SATELLITE_MODE=demo

# Google Earth Engine (required only for SATELLITE_MODE=live)
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=path/to/gee-key.json

# JWT Auth
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Demo user
DEMO_EMAIL=demo@terraledger.io
DEMO_PASSWORD=TerraDemo2026

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
